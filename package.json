{
  "name": "@tsingwong/template-lib-ts",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "keywords": [],
  "author": "tsingwong<tsongwoong@163.com>",
  "homepage": "https://github.com/tsingwong/template-lib-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsingwong/template-lib-ts.git"
  },
  "bugs": "https://github.com/tsingwong/template-lib-ts/issues",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.mjs"
    }
  },
  "source": "src/index.ts",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "watch": "wireit",
    "dev": "wireit",
    "test": "wireit",
    "clean": "wireit",
    "typecheck": "wireit",
    "lint": "wireit",
    "format": "wireit",
    "ci": "pnpm ci && pnpm run clean && pnpm run build && pnpm run lint && pnpm run test"
  },
  "wireit": {
    "watch": {
      "command": "parcel watch"
    },
    "build": {
      "command": "parcel build"
    },
    "dev": {
      "command": "nodemon --watch src --exec tsx src/index.ts"
    },
    "test": {
      "command": "vitest"
    },
    "typecheck": {
      "command": "tsc --noEmit"
    },
    "clean": {
      "command": "rm -rf dist"
    },
    "lint": {
      "command": "dprint check"
    },
    "format": {
      "command": "dprint fmt"
    }
  },
  "devDependencies": {
    "@gatsbyjs/parcel-namer-relative-to-cwd": "^2.15.0",
    "@parcel/bundler-library": "^2.16.4",
    "@parcel/config-default": "^2.16.4",
    "@parcel/packager-ts": "^2.16.4",
    "@parcel/transformer-typescript-types": "^2.16.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dprint": "^0.52.0",
    "lint-staged": "^16.3.3",
    "nodemon": "^3.1.14",
    "parcel": "^2.16.4",
    "parcel-namer-rewrite": "2.10.3-rc.5",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wireit": "^0.14.12"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "pnpm dprint check"
  },
  "publishConfig": {
    "access": "public"
  }
}
